    "/graph/top-products": {
      "get": {
        "summary": "Obtener los productos más pedidos",
        "tags": [
          "Graph"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de productos más vendidos"
          },
          "500": {
