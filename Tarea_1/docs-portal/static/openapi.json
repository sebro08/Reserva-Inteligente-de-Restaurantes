        ],
        "responses": {
          "200": {
            "description": "Usuario eliminado con éxito"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "description": "Forbidden - requiere rol admin_restaurante"
          },
          "404": {
            "description": "Usuario no encontrado"
          },
          "500": {
